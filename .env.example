KITH_DATA_DIR=/tmp/kith_data

# Backend: openai | anthropic | bedrock | ollama
KITH_LLM_BACKEND=bedrock
KITH_LLM_MODEL=claude-3-5-haiku-20241022
KITH_LLM_MAX_TOKENS=1024

# Caveman: lite | full | ultra
CAVEMAN_INTENSITY=full

# --- OpenAI ---
OPENAI_API_KEY=<your_openai_key>

# --- Anthropic ---
ANTHROPIC_API_KEY=<your_anthropic_key>

# --- Bedrock ---
AWS_BEARER_TOKEN_BEDROCK=<your_bedrock_token>
AWS_REGION=eu-west-2

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434/v1
